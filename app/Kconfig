mainmenu "LED Lab"

menuconfig LED_SUBSYSTEM
	bool "LED Subsystem"
	default y
	help
	  Enable LED subsystem.

if LED_SUBSYSTEM

choice LED_BLINK_SLEEP_TIME
	prompt "LED blink sleep time"
	default LED_BLINK_SLEEP_1S

config LED_BLINK_SLEEP_250MS
	bool "250ms"

config LED_BLINK_SLEEP_500MS
	bool "500ms"

config LED_BLINK_SLEEP_1S
	bool "1s (medium)"

config LED_BLINK_SLEEP_2S
	bool "2s"

endchoice

config LED_BLINK_SLEEP_TIME_MS
	int
	default 250 if LED_BLINK_SLEEP_250MS
	default 500 if LED_BLINK_SLEEP_500MS
	default 1000 if LED_BLINK_SLEEP_1S
	default 2000 if LED_BLINK_SLEEP_2S

menuconfig ADVANCED_LED_SETTINGS
	bool "Advanced LED settings"
	default n

if ADVANCED_LED_SETTINGS

config LED_BRIGHTNESS
	int "LED brightness (0-100)"
	range 0 100
	default 100

config LED_FADE_DURATION_MS
	int "LED fade duration (ms)"
	range 0 5000
	default 500

menu "Expert settings"
	visible if ADVANCED_LED_SETTINGS

config LED_DEBUGGING
	bool "Enable LED debugging"
	default n

config CUSTOM_BLINK_PATTERN
	bool "Custom blink pattern"
	default n

endmenu

endif # ADVANCED_LED_SETTINGS

endif # LED_SUBSYSTEM

source "Kconfig.zephyr"